---
import { iconTest } from '../../data/Categories';
---

<section
  id="categories"
  class="min-h-[30vh]"
  aria-labelledby="categories-heading"
>
    <h3 class="font-bold text-neutral-900">
      Icon Test
    </h3>
    <div class="grid grid-cols-10 gap-4">
    {
      iconTest.map((Icon) => (
        <div class="flex flex-col items-center gap-2 rounded-lg border border-neutral-200 p-4">
          <Icon class="h-10 w-10 text-primary" />
          <span class="text-xs text-neutral-600">{Icon.name}</span>
        </div>
      ))
    }
      </div>
</section>
