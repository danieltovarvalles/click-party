<svg
  viewBox="-35 0 140 140"
  class="logo-loader h-28 w-28"
>
  <g class="logo-body">
    <!-- cuerpo principal -->
    <path class="body" d="..." />

    <!-- estrella -->
    <path class="star" d="..." />

    <!-- confetis -->
    <path class="confetti confetti-1" d="..." />
    <path class="confetti confetti-2" d="..." />
    <path class="confetti confetti-3" d="..." />
    <path class="confetti confetti-4" d="..." />
  </g>
</svg>

<style>
.logo-loader{
    animation: floatLogo 2.5s ease-in-out infinite;
}

.star{
    transform-origin:center;
    animation: popStar 1.5s infinite;
}

.confetti{
    opacity:0;
}

.confetti-1{
    animation: reveal .5s .2s forwards;
}

.confetti-2{
    animation: reveal .5s .4s forwards;
}

.confetti-3{
    animation: reveal .5s .6s forwards;
}

.confetti-4{
    animation: reveal .5s .8s forwards;
}

@keyframes floatLogo{
    0%,100%{
        transform:translateY(0);
    }
    50%{
        transform:translateY(-8px);
    }
}

@keyframes popStar{
    0%,100%{
        transform:scale(1);
    }

    50%{
        transform:scale(1.2) rotate(10deg);
    }
}

@keyframes reveal{
    from{
        opacity:0;
        transform:translateY(10px) scale(.8);
    }

    to{
        opacity:1;
        transform:translateY(0) scale(1);
    }
}
</style>