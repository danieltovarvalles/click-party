---
import "../styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import BG from "../assets/icons/BG.astro";
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Click & Party",
  description = "Click & Party — eventos y experiencias.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      history.scrollRestoration = "manual";
    </script>
  </head>
  <body class="antialiased">
    <BG
      class="pointer-events-none fixed inset-0 -z-10 h-full w-full"
      aria-hidden="true"
    />
    <div id="page-scroll" class="relative bg-white-brand/60">
      <Header />
      <main class="relative mx-auto flex min-h-screen max-w-7xl flex-col gap-6 px-4 pb-4 sm:px-8">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      import { initPageScroll } from "../scripts/page-scroll.ts";
      initPageScroll();
    </script>
  </body>
</html>
