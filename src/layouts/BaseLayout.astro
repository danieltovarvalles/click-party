---
import "../styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import BG from "../assets/icons/BG.astro";
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Click & Party",
  description = "Click & Party — eventos y experiencias.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class=" antialiased"
  >
    <div id="page-scroll" class="bg-white-brand/60">
      <Header />
      <main class="relative mx-auto flex max-w-7xl flex-col gap-6 px-4 sm:px-8">
        <!-- <h1 class="sr-only">Click &amp; Party</h1> -->
        <slot />
      </main>
      <BG class="pointer-events-none absolute -z-10 top-0 left-0 h-full w-full" />
      <Footer />
    </div>
  </body>
</html>
