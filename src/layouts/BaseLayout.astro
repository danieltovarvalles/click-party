---
import "../styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import BG from "../assets/icons/BG.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Click & Party",
  description = "Click & Party — eventos y experiencias.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-5JMNVBH3");
    </script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      history.scrollRestoration = "manual";
    </script>
    <ViewTransitions />
  </head>
  <body class="antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-5JMNVBH3"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <BG
      class="pointer-events-none cursor-not-allowed fixed inset-0 -z-10 h-full w-full block"
      aria-hidden="true"
    />
    <div id="page-scroll" class="relative bg-white-brand/50">
      <Header />
      <main
        class="relative mx-auto flex min-h-screen max-w-7xl flex-col gap-6 px-4 pb-4 sm:px-8"
      >
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      import { initPageScroll } from "../scripts/page-scroll.ts";
      initPageScroll();
    </script>
  </body>
</html>
