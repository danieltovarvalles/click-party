---
import Logo2 from "../assets/icons/Click&Party_Horizontal_Mono.astro";
import { footerNav } from "../data/navigation";

const year = new Date().getFullYear();
---

<footer class="overflow-hidden bg-secondary py-6">
  <nav
    aria-label="Pie de página"
    class="mx-auto flex max-w-7xl flex-col gap-8 px-4 text-white sm:px-8 md:flex-row md:items-start md:justify-between"
  >
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-16">
      <div class="flex w-full max-w-[18rem] flex-col gap-2">
        <a href="/#hero" class="shrink-0">
          <Logo2 class="h-auto text-white" />
        </a>
        <p class="text-[10px] sm:text-xs leading-snug text-white/90">
          Click & Party {year} conecta a empresas y clientes para facilitar la conexión
          entre ellos, ayudando a los emprendedores a crecer y a los clientes a encontrar
          los mejores servicios.
        </p>
      </div>
      {
        footerNav.map((category) => (
          <div>
            <h5 class="mb-2 text-xs font-bold uppercase tracking-wide text-white">
              {category.title}
            </h5>
            <ul class="flex flex-col text-sm">
              {category.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    target={item.openOnNewTab ? "_blank" : undefined}
                    rel={item.openOnNewTab ? "noopener noreferrer" : undefined}
                    class="text-[10px] sm:text-xs font-semibold leading-none text-white/90 transition-colors hover:text-white"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </nav>
</footer>
