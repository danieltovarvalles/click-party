---
import Logo2 from "../assets/icons/Click&Party.astro";
import { mainNav } from "../data/Navigation";
---

<header
  data-scroll-spy
  class="sticky top-0 z-50 border-b border-neutral-200 bg-white/95 shadow-sm backdrop-blur supports-[backdrop-filter]:bg-white/80"
>
  <div class="relative mx-auto flex max-w-7xl items-center justify-between px-4 py-2 sm:px-8">
    <a href="/#hero" class="shrink-0 text-lg font-semibold tracking-tight text-neutral-900">
      <Logo2 class="h-8 w-auto sm:h-16" />
    </a>

    <button
      type="button"
      class="inline-flex items-center justify-center rounded-md p-2 text-black-brand hover:bg-neutral-100 md:hidden"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="main-nav"
      data-menu-toggle
    >
      <svg
        class="h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
    </button>

    <nav
      id="main-nav"
      aria-label="Principal"
      data-nav-panel
      data-open="false"
      class="absolute left-0 right-0 top-full hidden border-b border-neutral-200 bg-white px-4 py-4 shadow-md data-[open=true]:block md:static md:block md:border-0 md:bg-transparent md:p-0 md:shadow-none"
    >
      <ul class="flex flex-col gap-4 font-semibold md:flex-row md:items-center md:gap-8">
        {
          mainNav.map(({ label, href }) => (
            <li>
              <a
                href={href}
                data-nav-link
                class="block text-black-brand transition-colors hover:text-primary"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  import "../scripts/scroll-spy.ts";
  import {
    initHeader,
    initPageAnchorNavigation,
    scrollToHashOnLoad,
  } from "../scripts/header-nav.ts";

  initPageAnchorNavigation();
  document.querySelectorAll<HTMLElement>("[data-scroll-spy]").forEach(initHeader);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scrollToHashOnLoad, {
      once: true,
    });
  } else {
    scrollToHashOnLoad();
  }
</script>
